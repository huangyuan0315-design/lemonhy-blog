---
import BaseLayout from "../components/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEO from "../components/SEO.astro";
---

<BaseLayout>
  <SEO slot="head" title="图片展示" description="照片画廊" />
  <Header />
  <main class="flex-1 max-w-6xl mx-auto px-4 py-12 w-full">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">图片展示</h1>
    <div id="gallery-grid" class="columns-1 sm:columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4"></div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const API = "https://lemonhy-comments-api.huangyuan0315.workers.dev";

  (async function () {
    const grid = document.getElementById("gallery-grid")!;
    try {
      const res = await fetch(`${API}/api/public/images`);
      const images = await res.json();

      if (!Array.isArray(images) || images.length === 0) {
        grid.innerHTML = '<p class="text-gray-400 dark:text-gray-500 text-center py-16 col-span-full">暂无图片</p>';
        return;
      }

      grid.innerHTML = images
        .map(
          (img) => `
        <div class="break-inside-avoid rounded-xl overflow-hidden bg-gray-50 dark:bg-gray-800/30 group">
          <a href="${img.url}" target="_blank" class="block">
            <img src="${img.url}" alt="${img.name}" loading="lazy"
              class="w-full object-cover group-hover:opacity-90 transition-opacity"
              onerror="this.parentElement.parentElement.remove()" />
          </a>
          <div class="px-3 py-2.5 flex items-center justify-between">
            <p class="text-xs text-gray-500 dark:text-gray-400">
              ${new Date(img.date).toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
              })}
              <span class="ml-1 text-gray-300 dark:text-gray-600">${new Date(img.date).toLocaleTimeString("zh-CN", {
                hour: "2-digit",
                minute: "2-digit",
              })}</span>
            </p>
            <span class="text-xs text-gray-400 dark:text-gray-500 truncate ml-2 max-w-[60%]" title="${img.name}">${img.name}</span>
          </div>
        </div>`
        )
        .join("");
    } catch {
      grid.innerHTML = '<p class="text-red-500 text-center py-16">加载失败</p>';
    }
  })();
</script>
