---
import { getCollection } from "astro:content";
import BaseLayout from "../../../components/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import SEO from "../../../components/SEO.astro";

const allPosts = await getCollection("posts");
const published = allPosts.filter((p) => !p.data.draft);
const tagCounts = published.reduce(
  (acc, p) => {
    for (const tag of p.data.tags) {
      acc[tag] = (acc[tag] || 0) + 1;
    }
    return acc;
  },
  {} as Record<string, number>
);

const sorted = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout>
  <SEO slot="head" title="标签" description="按标签浏览文章" />
  <Header />
  <main class="flex-1 max-w-4xl mx-auto px-4 py-12 w-full">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">标签</h1>
    <div class="flex flex-wrap gap-3">
      {sorted.map(([tag, count]) => (
        <a
          href={`/blog/tag/${tag}`}
          class="inline-block px-4 py-2 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-primary-100 dark:hover:bg-primary-900/30 hover:text-primary-700 dark:hover:text-primary-400 transition-all text-sm"
        >
          {tag}
          <span class="ml-1.5 text-xs text-gray-400 dark:text-gray-500">{count}</span>
        </a>
      ))}
    </div>
    {sorted.length === 0 && (
      <p class="text-gray-500 dark:text-gray-400 py-12 text-center">暂无标签</p>
    )}
  </main>
  <Footer />
</BaseLayout>
