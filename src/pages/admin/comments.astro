---
import BaseLayout from "../../components/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SEO from "../../components/SEO.astro";
---

<BaseLayout>
  <SEO slot="head" title="评论管理" description="评论审核管理" />
  <Header />
  <main class="flex-1 max-w-4xl mx-auto px-4 py-12 w-full" id="admin-root">
    <div id="login-panel"></div>
    <div id="dashboard" class="hidden"></div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const API = "https://lemonhy-comments-api.huangyuan0315.workers.dev";

  function getToken() {
    return sessionStorage.getItem("admin_token");
  }

  function authHeader() {
    return { Authorization: `Bearer ${getToken()}` };
  }

  // ── Login ──
  const loginPanel = document.getElementById("login-panel")!;
  const dashboard = document.getElementById("dashboard")!;

  if (getToken()) {
    showDashboard();
  } else {
    showLogin();
  }

  function showLogin() {
    loginPanel.innerHTML = `
      <div class="max-w-sm mx-auto mt-16">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6 text-center">
          管理员登录
        </h1>
        <form id="login-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">管理员密码</label>
            <input type="password" name="password" required autofocus
              class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none" />
          </div>
          <p id="login-msg" class="text-sm text-red-500 hidden"></p>
          <button type="submit"
            class="w-full py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors cursor-pointer font-medium">
            登录
          </button>
        </form>
      </div>
    `;

    document.getElementById("login-form")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const pwd = (e.target as HTMLFormElement).elements.namedItem("password") as HTMLInputElement;
      const msg = document.getElementById("login-msg")!;

      try {
        const res = await fetch(`${API}/api/admin/comments`, {
          headers: { Authorization: `Bearer ${pwd.value.trim()}` },
        });
        if (res.ok) {
          sessionStorage.setItem("admin_token", pwd.value.trim());
          loginPanel.innerHTML = "";
          showDashboard();
        } else {
          msg.textContent = "密码错误";
          msg.classList.remove("hidden");
        }
      } catch {
        msg.textContent = "网络错误，请稍后再试";
        msg.classList.remove("hidden");
      }
    });
  }

  function showDashboard() {
    loginPanel.innerHTML = "";
    dashboard.classList.remove("hidden");
    dashboard.innerHTML = `
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">评论管理</h1>
        <button id="logout-btn"
          class="px-3 py-1.5 text-sm text-gray-500 hover:text-red-500 dark:text-gray-400 dark:hover:text-red-400 transition-colors cursor-pointer">
          退出登录
        </button>
      </div>
      <div class="flex gap-2 mb-4" id="tabs"></div>
      <div id="comment-list" class="space-y-3"></div>
    `;

    document.getElementById("logout-btn")!.onclick = () => {
      sessionStorage.removeItem("admin_token");
      dashboard.classList.add("hidden");
      showLogin();
    };

    renderTabs("pending");
    loadComments("pending");
  }

  function renderTabs(active) {
    const tabs = [
      { key: "pending", label: "待审核" },
      { key: "approved", label: "已通过" },
      { key: "spam", label: "垃圾" },
    ];
    document.getElementById("tabs")!.innerHTML = tabs
      .map(
        (t) =>
          `<button data-tab="${t.key}"
            class="px-4 py-1.5 text-sm rounded-full cursor-pointer transition-colors ${
              active === t.key
                ? "bg-primary-600 text-white"
                : "bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700"
            }">${t.label}</button>`
      )
      .join("");

    document.querySelectorAll("[data-tab]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const tab = (btn as HTMLElement).dataset.tab!;
        renderTabs(tab);
        loadComments(tab);
      });
    });
  }

  async function loadComments(status) {
    const list = document.getElementById("comment-list")!;
    list.innerHTML =
      '<p class="text-gray-400 dark:text-gray-500 text-sm py-8 text-center">加载中...</p>';

    try {
      const res = await fetch(`${API}/api/admin/comments?status=${status}`, {
        headers: authHeader(),
      });
      const comments = await res.json();

      if (!Array.isArray(comments) || comments.length === 0) {
        list.innerHTML =
          '<p class="text-gray-400 dark:text-gray-500 text-sm py-8 text-center">暂无评论</p>';
        return;
      }

      list.innerHTML = comments
        .map(
          (c) => `
        <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800/30">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-medium text-gray-900 dark:text-white">${esc(c.author)}</span>
                <span class="text-xs text-gray-400 dark:text-gray-500">${new Date(c.created_at).toLocaleString("zh-CN")}</span>
                <span class="text-xs px-1.5 py-0.5 rounded ${statusBadge(c.status)}">${statusLabel(c.status)}</span>
              </div>
              <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">文章: ${esc(c.post_slug)}</p>
              <p class="text-sm text-gray-700 dark:text-gray-300">${esc(c.body)}</p>
            </div>
            <div class="flex gap-1 shrink-0">
              ${c.status !== "approved" ? btn("✓", "批准", "approved", "bg-green-600 hover:bg-green-700", c.id) : ""}
              ${c.status !== "spam" ? btn("✗", "标记垃圾", "spam", "bg-yellow-600 hover:bg-yellow-700", c.id) : ""}
              ${c.status !== "pending" ? btn("⟲", "待审", "pending", "bg-gray-600 hover:bg-gray-700", c.id) : ""}
              <button data-delete="${c.id}" class="px-2 py-1 text-xs rounded bg-red-600 hover:bg-red-700 text-white cursor-pointer transition-colors" title="删除">
                删除
              </button>
            </div>
          </div>
        </div>`
        )
        .join("");

      // Action handlers
      list.querySelectorAll("[data-approve]").forEach((b) =>
        b.addEventListener("click", () => updateStatus(b.dataset.approve!, "approved"))
      );
      list.querySelectorAll("[data-spam]").forEach((b) =>
        b.addEventListener("click", () => updateStatus(b.dataset.spam!, "spam"))
      );
      list.querySelectorAll("[data-pending]").forEach((b) =>
        b.addEventListener("click", () => updateStatus(b.dataset.pending!, "pending"))
      );
      list.querySelectorAll("[data-delete]").forEach((b) =>
        b.addEventListener("click", () => deleteComment(b.dataset.delete!))
      );
    } catch {
      list.innerHTML =
        '<p class="text-red-500 text-sm py-8 text-center">加载失败，请检查网络连接</p>';
    }
  }

  function btn(icon, title, status, color, id) {
    return `<button data-${status}="${id}" class="px-2 py-1 text-xs rounded ${color} text-white cursor-pointer transition-colors" title="${title}">${icon}</button>`;
  }

  async function updateStatus(id, status) {
    try {
      const res = await fetch(`${API}/api/admin/comments/${id}`, {
        method: "PATCH",
        headers: { ...authHeader(), "Content-Type": "application/json" },
        body: JSON.stringify({ status }),
      });
      if (res.ok) {
        const activeTab = document.querySelector("[data-tab].bg-primary-600")?.getAttribute("data-tab") || "pending";
        loadComments(activeTab);
      }
    } catch {}
  }

  async function deleteComment(id) {
    if (!confirm("确定要删除这条评论吗？")) return;
    try {
      const res = await fetch(`${API}/api/admin/comments/${id}`, {
        method: "DELETE",
        headers: authHeader(),
      });
      if (res.ok) {
        const activeTab = document.querySelector("[data-tab].bg-primary-600")?.getAttribute("data-tab") || "pending";
        loadComments(activeTab);
      }
    } catch {}
  }

  function esc(text) {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function statusLabel(s) {
    return { pending: "待审", approved: "已通过", spam: "垃圾" }[s] || s;
  }

  function statusBadge(s) {
    return {
      pending: "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400",
      approved: "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
      spam: "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400",
    }[s] || "";
  }
</script>
