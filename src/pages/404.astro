---
import BaseLayout from "../components/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <Header />
  <main class="flex-1 max-w-4xl mx-auto px-4 py-24 w-full text-center">
    <h1 class="text-6xl font-bold text-gray-200 dark:text-gray-800 mb-4">404</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">页面未找到</p>
    <a
      href="/"
      class="inline-block px-6 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm"
    >
      返回首页
    </a>
  </main>
  <Footer />
</BaseLayout>
